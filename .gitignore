# ============================================
# 操作系统忽略规则
# ============================================

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory

# ============================================
# 编辑器和IDE忽略规则
# ============================================

# VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets

# JetBrains IDEs (IntelliJ, PyCharm, WebStorm, etc.)
.idea/
*.iws
*.iml
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp

# ============================================
# 后端 Python 忽略规则
# ============================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.env
.venv
env/
venv/
ENV/
.venv/

# Pipenv
Pipfile.lock

# Poetry
poetry.lock

# pyenv
.python-version

# pip
pip-log.txt
pip-delete-this-directory.txt

# pytest
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.py,cover
.hypothesis/

# mypy
.mypy_cache/

# ruff
.ruff_cache/

# celery
celerybeat-schedule
celerybeat.pid

# Flask
instance/
.webassets-cache

# SQLAlchemy
*.db
*.sqlite
*.sqlite3

# Migrations
backend/migrations/versions/*.py
!backend/migrations/versions/__init__.py

# ============================================
# 前端 Node.js 忽略规则
# ============================================

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov/

# Coverage directory used by tools like istanbul
coverage/
*.lcov

# nyc test coverage
.nyc_output/

# Dependency directories
node_modules/
jspm_packages/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm/

# Optional eslint cache
.eslintcache/

# Optional stylelint cache
.stylelintcache/

# Optional REPL history
.node_repl_history/

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variable files
.env
.env.*
!.env.example

# parcel-bundler cache
.cache/
.parcel-cache/

# Next.js build output
.next/
out/

# Nuxt.js build / generate output
.nuxt/

# Vite build output
dist/

# Vite logs files
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Sveltekit cache directory
.svelte-kit/

# vuepress build output
.vuepress/dist/

# vuepress v2.x temp and cache directory
.temp/

# Docusaurus cache and generated files
.docusaurus/

# Serverless directories
.serverless/

# FuseBox cache
.fusebox/

# DynamoDB Local files
.dynamodb/

# Firebase cache directory
.firebase/

# TernJS port file
.tern-port

# Stores VSCode versions used for testing VSCode extensions
.vscode-test/

# yarn v3
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# ============================================
# Docker 忽略规则
# ============================================

# Docker volumes (shouldn't be committed)
.docker-volumes/

# ============================================
# 项目特定忽略规则
# ============================================

# 数据库文件
*.db
*.sqlite
*.sqlite3

# 本地配置文件
.env
.env.local
.env.*.local
!.env.example

# 上传文件
uploads/
media/

# 临时文件
tmp/
temp/

# 缓存文件
*.cache/

# 空目录保持
!.gitkeep

# ============================================
# 前后端分离项目特定规则
# ============================================

# 后端特定
backend/.venv/
backend/env/
backend/__pycache__/
backend/*.pyc
backend/.pytest_cache/
backend/.mypy_cache/
backend/instance/

# 前端特定
frontend/node_modules/
frontend/dist/
frontend/.cache/
frontend/.parcel-cache/
frontend/.env.local
